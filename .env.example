# Hybrid Hierarchical LLM Router - Example Configuration

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
# Add any other litellm-supported provider keys here.

# ── Router Defaults ───────────────────────────────────────────────────────────
# Default model used when no routing decision overrides it.
DEFAULT_MODEL=gpt-4o-mini

# Model used when PII is detected (must be a private/on-prem endpoint).
PRIVATE_MODEL=ollama/llama3

# Small LLM used by the Layer 3 agent router.
AGENT_ROUTER_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Leave blank to use in-memory Qdrant instance.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=router_history

# Similarity threshold above which Layer 2 will make a routing decision.
SEMANTIC_THRESHOLD=0.85

# ── Embedding Model ───────────────────────────────────────────────────────────
# Local sentence-transformers model identifier.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path (relative to project root) or a PostgreSQL DSN.
DATABASE_URL=sqlite+aiosqlite:///./data/router.db

# ── Tri-Modal Orchestrator ─────────────────────────────────────────────────────

# Mode 3: Agentic Engine — get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# Mode 3: LLM used by the ReAct agent for reasoning and tool orchestration.
AGENTIC_MODEL=gpt-4o-mini

# Mode 3: Maximum number of reasoning steps before the agent gives a summary.
AGENTIC_MAX_STEPS=5

# Mode 3: Hard timeout in seconds for the full agentic loop.
AGENTIC_TIMEOUT_SECONDS=30.0

# Verifier: Enable/disable the Mode 1 output sanity check (Speculative Decoding).
VERIFIER_ENABLED=true
VERIFIER_MODEL=gpt-4o-mini

# Classifier: Semantic similarity threshold for Layer 2 mode classification.
# Queries above this score are routed to Mode 2 without calling the LLM classifier.
SEMANTIC_SIMILARITY_THRESHOLD=0.82
